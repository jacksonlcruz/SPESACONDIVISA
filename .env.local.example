# Variáveis de Ambiente — copie este arquivo para .env.local e preencha os valores

# ──────────────────────────────────────────────────────────
# SUPABASE
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ──────────────────────────────────────────────────────────
# SUPABASE SERVICE ROLE (opcional — necessário para deleção completa
# de conta via /api/auth/delete-account. Sem essa chave, os dados
# públicos são deletados mas o registro auth.user permanece.)
# ──────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ──────────────────────────────────────────────────────────
# OPENAI  (usado na API Route server-side — NUNCA expor no cliente)
# ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
